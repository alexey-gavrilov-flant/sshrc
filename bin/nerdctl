#!/bin/bash
cmd=$(find.bin nerdctl)
if [ "$cmd" = "" ]; then
  mkdir -p ~/bin
  if [ -n "$PROXY_PORT" ]; then proxy="--socks5-hostname 127.0.0.1:$PROXY_PORT"; fi
  curl $proxy -L "https://github.com/containerd/nerdctl/releases/download/v2.2.2/nerdctl-2.2.2-linux-amd64.tar.gz" | tar -xz -C ~/bin/ nerdctl
  cmd=$(find.bin nerdctl)
fi
if [ "$cmd" != "" ]; then
  if [ "$EUID" -ne 0 ]; then
    exec sudo $cmd "$@"
  else
    exec $cmd "$@"
  fi
fi
