#!/bin/bash
cmd=$(find.bin trivy)
if [ "$cmd" = "" ]; then
  mkdir -p ~/bin
  if [ -n "$PROXY_PORT" ]; then proxy="--socks5-hostname 127.0.0.1:$PROXY_PORT"; fi
  curl $proxy -L "http://127.0.0.1:81/trivy" > ~/bin/trivy
  chmod +x ~/bin/trivy
  cmd=$(find.bin trivy)
fi
if [ "$cmd" != "" ]; then
  exec $cmd "$@"
fi
